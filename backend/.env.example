# Database Configuration
# Leave DATABASE_URL empty to use the simple in-memory fallback (simple-server)
# To enable PostgreSQL, set DATABASE_URL to your Postgres connection string
# Example: DATABASE_URL=postgresql://username:password@host:5432/database
DATABASE_URL=

# Security - CHANGE THESE IN PRODUCTION!
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARACTERS_LONG
NODE_ENV=development

# Server
PORT=5001

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Supabase (Alternative to PostgreSQL)
# If you use Supabase instead of DATABASE_URL, set these values.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Default Admin Credentials (CHANGE THESE!)
DEFAULT_ADMIN_USERNAME=hunter
DEFAULT_ADMIN_PASSWORD=hunter_admin1234
